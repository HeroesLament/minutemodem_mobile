   @doc """
+  Issue a USB control transfer on endpoint 0 (the device's default control
+  pipe). This is the generic primitive underneath device-specific control
+  protocols — line coding, modem-handshake lines (RTS/DTR), vendor requests.
+  The framework stays device-agnostic: encode the `request_type`/`request`/
+  `value`/`index`/`data` for your chip in app-side code (e.g. a CP2102 or
+  FTDI module).
+
+  Arguments mirror `UsbDeviceConnection.controlTransfer/7`:
+    * `request_type` — bmRequestType. Bit 7 set (e.g. `0xC1`) means
+      device→host (a read); clear (e.g. `0x41`) means host→device.
+    * `request` — bRequest.
+    * `value` — wValue.
+    * `index` — wIndex.
+    * `data` — payload binary/iolist. For host→device this is the bytes to
+      send (often empty for value-only requests). For device→host its byte
+      size sizes the read buffer.
+
+  Options:
+    * `:timeout_ms` — transfer timeout (default `1000`).
+
+  Result:
+    * `{:peripheral, :vendor_usb, :control_result, session, %{result: n, data: binary}}`
+      where `result` is the controlTransfer return (bytes transferred, or
+      negative on error) and `data` is the bytes read (empty for
+      host→device requests).
+    * `{:peripheral, :vendor_usb, :error, session, reason}` — e.g.
+      `:no_session`, `:control_failed`.
+  """
+  @spec control_transfer(
+          Mob.Socket.t(),
+          session(),
+          non_neg_integer(),
+          non_neg_integer(),
+          non_neg_integer(),
+          non_neg_integer(),
+          iodata(),
+          keyword()
+        ) :: Mob.Socket.t()
+  def control_transfer(socket, session, request_type, request, value, index, data \\ <<>>, opts \\ [])
+      when is_integer(session) and is_integer(request_type) and is_integer(request) and
+             is_integer(value) and is_integer(index) do
+    bin = IO.iodata_to_binary(data)
+
+    if byte_size(bin) > @max_write_bytes do
+      send(self(), {:peripheral, :vendor_usb, :error, session, :payload_too_large})
+      socket
+    else
+      timeout = Keyword.get(opts, :timeout_ms, 1000)
+      :mob_nif.vendor_usb_control_transfer(session, request_type, request, value, index, bin, timeout)
+      socket
+    end
+  end
+
