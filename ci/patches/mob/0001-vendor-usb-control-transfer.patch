+// ── Mob.AudioPcm NIFs ────────────────────────────────────────────────────
+//
+// Real-time PCM duplex bridge. Thin wrappers over MobBridge's
+// audio_pcm_* @JvmStatic methods. list_devices/open dispatch and return
+// :ok immediately; results arrive async via mob_deliver_file_result
+// ({audio_pcm, devices|opened, json}) and mob_deliver_audio_pcm_data
+// (streamed capture). write is DIRTY_IO (blocking AudioTrack.write off a
+// dirty scheduler). All four are optional — older MobBridge templates
+// without the PCM block short-circuit with :unsupported, mirroring the
+// vendor_usb stubs.
+
+fn audioPcmUnsupported(env: ?*erts.ErlNifEnv) erts.ERL_NIF_TERM {
+    var pid: erts.ErlNifPid = undefined;
+    _ = erts.enif_self(env, &pid);
+    const msg_env = erts.enif_alloc_env() orelse return erts.ok(env);
+    defer erts.enif_free_env(msg_env);
+    const msg = erts.makeTuple(msg_env, .{
+        erts.atom(msg_env, "audio_pcm"),
+        erts.atom(msg_env, "error"),
+        erts.atom(msg_env, "unsupported"),
+    });
+    _ = erts.enif_send(null, &pid, msg_env, msg);
+    return erts.ok(env);
+}
