+// nif_audio_pcm_write/2 — enqueue PCM bytes to a session's AudioTrack.
+// DIRTY_IO: the Kotlin side runs AudioTrack.write off-thread, but the
+// byte[] marshalling + static call still want a dirty scheduler under
+// sustained TX. Mirrors vendor_usb_bulk_write.
+export fn nif_audio_pcm_write(
+    env: ?*erts.ErlNifEnv,
+    argc: c_int,
+    argv: [*]const erts.ERL_NIF_TERM,
+) callconv(.c) erts.ERL_NIF_TERM {
+    _ = argc;
+    if (Bridge.audio_pcm_write == null) return audioPcmUnsupported(env);
+    var session: c_int = 0;
+    if (erts.enif_get_int(env, argv[0], &session) == 0) return erts.badarg(env);
+    const bin = getBinOrIolist(env, argv[1]) orelse return erts.badarg(env);
+
+    var pid: erts.ErlNifPid = undefined;
+    _ = erts.enif_self(env, &pid);
+
+    var attached: c_int = 0;
+    const jenv = get_jenv(&attached) orelse return erts.atom(env, "error");
+    defer detachIfAttached(attached);
+
+    const size: jni.JSize = @intCast(bin.size);
+    const jbytes = jni.newByteArray(jenv, size);
+    if (jbytes != null) {
+        jni.setByteArrayRegion(jenv, jbytes, 0, size, @ptrCast(bin.data));
+        jenv.*.CallStaticVoidMethod.?(
+            jenv,
+            Bridge.cls,
+            Bridge.audio_pcm_write,
+            pidToJlong(pid),
+            @as(jni.JInt, session),
+            jbytes,
+        );
+        jni.deleteLocalRef(jenv, jbytes);
+    }
+    return erts.ok(env);
+}
