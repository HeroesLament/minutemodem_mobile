+// nif_vendor_usb_control_transfer/7 — generic USB control transfer.
+//
+// Carries the full UsbDeviceConnection.controlTransfer signature so all
+// device-specific protocols (CP2102 line-coding + RTS/DTR for PTT, etc.)
+// can be expressed app-side in Elixir without a per-chip native method.
+// argv: session, request_type, request, value, index, data (binary,
+// possibly empty), timeout_ms. The `data` bytes are the control-transfer
+// payload (host->device) or ignored buffer length hint (device->host:
+// Kotlin sizes the read buffer from data.length). Result (the
+// controlTransfer return + any read bytes) arrives async via
+// mob_deliver_vendor_usb_control_result. DIRTY_IO: the Kotlin side does a
+// synchronous blocking controlTransfer off a worker thread.
+export fn nif_vendor_usb_control_transfer(
+    env: ?*erts.ErlNifEnv,
+    argc: c_int,
+    argv: [*]const erts.ERL_NIF_TERM,
+) callconv(.c) erts.ERL_NIF_TERM {
+    _ = argc;
+    if (Bridge.vendor_usb_control_transfer == null) return vendorUsbUnsupported(env);
+    var session: c_int = 0;
+    if (erts.enif_get_int(env, argv[0], &session) == 0) return erts.badarg(env);
+    var request_type: c_int = 0;
+    if (erts.enif_get_int(env, argv[1], &request_type) == 0) return erts.badarg(env);
+    var request: c_int = 0;
+    if (erts.enif_get_int(env, argv[2], &request) == 0) return erts.badarg(env);
+    var value: c_int = 0;
+    if (erts.enif_get_int(env, argv[3], &value) == 0) return erts.badarg(env);
+    var index: c_int = 0;
+    if (erts.enif_get_int(env, argv[4], &index) == 0) return erts.badarg(env);
+    const bin = getBinOrIolist(env, argv[5]) orelse return erts.badarg(env);
+    var timeout_ms: c_int = 1000;
+    if (erts.enif_get_int(env, argv[6], &timeout_ms) == 0) return erts.badarg(env);
+
+    var pid: erts.ErlNifPid = undefined;
+    _ = erts.enif_self(env, &pid);
+
+    var attached: c_int = 0;
+    const jenv = get_jenv(&attached) orelse return erts.atom(env, "error");
+    defer detachIfAttached(attached);
+
+    // Copy the control-transfer payload into a fresh Java byte[] (may be
+    // zero-length — a value-only transfer like IFC_ENABLE / SET_MHS). Kotlin
+    // hands it to UsbDeviceConnection.controlTransfer and, for device->host
+    // requests, reads the response back into it.
+    const size: jni.JSize = @intCast(bin.size);
+    const jbytes = jni.newByteArray(jenv, size);
+    if (jbytes != null) {
+        if (size > 0) jni.setByteArrayRegion(jenv, jbytes, 0, size, @ptrCast(bin.data));
+        jenv.*.CallStaticVoidMethod.?(
+            jenv,
+            Bridge.cls,
+            Bridge.vendor_usb_control_transfer,
+            pidToJlong(pid),
+            @as(jni.JInt, session),
+            @as(jni.JInt, request_type),
+            @as(jni.JInt, request),
+            @as(jni.JInt, value),
+            @as(jni.JInt, index),
+            jbytes,
+            @as(jni.JInt, timeout_ms),
+        );
+        jni.deleteLocalRef(jenv, jbytes);
+    }
+    return erts.ok(env);
+}
