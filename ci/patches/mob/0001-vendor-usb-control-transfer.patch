+// nif_audio_pcm_open/1 — open a pinned duplex PCM stream from an opts JSON
+// binary (sample_rate, channels, record_device_id, play_device_id,
+// unprocessed, chunk_frames). Returns :ok; the session id arrives via the
+// {audio_pcm, opened, json} file-result event.
+export fn nif_audio_pcm_open(
+    env: ?*erts.ErlNifEnv,
+    argc: c_int,
+    argv: [*]const erts.ERL_NIF_TERM,
+) callconv(.c) erts.ERL_NIF_TERM {
+    _ = argc;
+    if (Bridge.audio_pcm_open == null) return audioPcmUnsupported(env);
+    const bin = getBinOrIolist(env, argv[0]) orelse return erts.badarg(env);
+    const json = binToCString(bin) orelse return erts.atom(env, "error");
+    defer freeCString(json);
+    var pid: erts.ErlNifPid = undefined;
+    _ = erts.enif_self(env, &pid);
+    return callBridgePidStr(env, Bridge.audio_pcm_open, pid, json);
