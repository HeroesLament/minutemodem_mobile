-    case System.cmd("cargo", args, stderr_to_stdout: true, into: IO.stream()) do
+    # Per-NIF extra build environment from mob.exs. A NIF whose build.rs needs
+    # to find a cross-built native library (e.g. hamlib_nif locating the NDK
+    # static libhamlib.a via HAMLIB_INCLUDE_DIR / HAMLIB_LIB_DIR) declares it
+    # under `config :mob_dev, nif_build_env: %{<module> => %{"VAR" => "val"}}`.
+    # Without this, build.rs falls back to pkg-config and links the host copy.
+    #
+    # mob.exs is config data, not loaded into Application env — read it the
+    # same way mob.regen_driver_tab reads :static_nifs (Config.Reader, with an
+    # Application.get_env fallback for programmatic overrides in tests).
+    mob_exs_env =
+      if File.exists?("mob.exs") do
+        Config.Reader.read!("mob.exs")
+        |> Keyword.get(:mob_dev, [])
+        |> Keyword.get(:nif_build_env, Application.get_env(:mob_dev, :nif_build_env, %{}))
+      else
+        Application.get_env(:mob_dev, :nif_build_env, %{})
+      end
+
+    nif_env =
+      mob_exs_env
+      |> Map.get(String.to_atom(name), %{})
+      |> Enum.map(fn {k, v} -> {to_string(k), to_string(v)} end)
+
+    if nif_env != [] do
+      Mix.shell().info("      with env: #{Enum.map_join(nif_env, " ", fn {k, _} -> k end)}")
+    end
+
+    case System.cmd("cargo", args, stderr_to_stdout: true, into: IO.stream(), env: nif_env) do
       {_, 0} ->
         a = Path.expand("native/#{name}/target/#{target}/release/lib#{name}.a")
 
